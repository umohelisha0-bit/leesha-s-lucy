# Leesha's Lucy AI Video Call - Environment Configuration

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://lucy_user:lucy_password@db:5432/lucy_ai
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://redis:6379

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Anthropic Claude API (optional)
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-opus-20240229

# ElevenLabs Text-to-Speech
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Whisper Speech Recognition
WHISPER_MODEL=base
WHISPER_LANGUAGE=en

# Avatar Configuration
AVATAR_MODEL=gan
AVATAR_RESOLUTION=1080p
AVATAR_FPS=30

# WebSocket Configuration
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Session Configuration - UNLIMITED (NO TIME RESTRICTIONS)
SESSION_TIMEOUT=None
SESSION_MAX_DURATION=None
SESSION_IDLE_CHECK_INTERVAL=300
